<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title>Copygames</title>
  <style>
    :root { color-scheme: dark; --muted:#a5a9b5; --line:#3d414a; }
    * { box-sizing: border-box; }
    body { margin:0; font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; color:#fff; background:#030405; }
    .hidden { display:none !important; }

    /* Sign-in page */
    .signin-body { min-height:100vh; display:grid; place-items:center; padding:42px 18px; background:radial-gradient(circle at 50% 43%, rgba(22,25,31,.34) 0%, rgba(8,10,13,.18) 42%, transparent 68%), #030405; }
    .card { width:min(520px,100%); padding:36px 40px 40px; text-align:center; border:1px solid rgba(130,135,146,.55); border-radius:34px; background:linear-gradient(145deg, rgba(25,27,33,.88), rgba(9,11,15,.88)); box-shadow:0 30px 90px rgba(0,0,0,.5), inset 0 1px 0 rgba(255,255,255,.03); backdrop-filter:blur(16px); }
    .brand { width:110px; height:110px; margin:0 auto 18px; border-radius:27px; overflow:hidden; background:#15171d; box-shadow:0 14px 30px rgba(0,0,0,.4); }
    .brand img { width:100%; height:100%; object-fit:cover; display:block; }
    h1 { margin:0; font-size:clamp(32px,5vw,40px); line-height:1.1; letter-spacing:-1.8px; }
    .subtitle { margin:12px 0 28px; color:var(--muted); font-size:19px; }
    .field { text-align:left; margin:0 0 25px; }
    label { display:block; margin:0 0 10px; color:#bdc1cb; font-size:17px; }
    .control { position:relative; }
    .control > svg { position:absolute; left:24px; top:50%; transform:translateY(-50%); color:#aeb3c0; }
    input { width:100%; height:58px; padding:0 62px; color:#fff; font:inherit; font-size:17px; border:1px solid var(--line); border-radius:13px; outline:none; background:rgba(7,9,13,.6); transition:.2s border-color,.2s box-shadow; }
    input::placeholder { color:#9ca1af; }
    input:focus { border-color:#8e96a8; box-shadow:0 0 0 3px rgba(180,190,215,.1); }
    .eye { position:absolute; right:18px; top:50%; translate:0 -50%; padding:8px; color:#afb4c0; border:0; background:none; cursor:pointer; }
    .primary { width:100%; min-height:58px; border-radius:13px; font-family:inherit; font-weight:700; cursor:pointer; margin-top:4px; border:0; color:#08090b; background:#fff; font-size:22px; }
    .primary:hover { background:#e9e9eb; }
    .switch-text { margin:14px 0 0; color:#9fa4b0; font-size:14px; }
    .link-button { border:0; padding:2px 4px; color:#fff; background:none; font:700 inherit; cursor:pointer; }
    .link-button:hover { text-decoration:underline; }

    /* Main site */
    .main-site { display:none; }
    .main-site.show { display:block; }
    .site-header { display:flex; align-items:center; justify-content:space-between; padding:20px 40px; background:rgba(9,11,15,.95); border-bottom:1px solid var(--line); }
    .site-header .brand { width:60px; height:60px; margin:0; }
    .nav { display:flex; gap:24px; }
    .nav a { color:#fff; text-decoration:none; font-weight:600; }
    .nav a:hover { color:#8e96a8; }
    .hero { padding:80px 40px; text-align:center; }
    .hero h1 { font-size:clamp(42px,6vw,64px); margin-bottom:20px; }
    .hero p { font-size:22px; color:var(--muted); max-width:700px; margin:0 auto 40px; }
    .cta-button { display:inline-block; padding:18px 48px; background:#fff; color:#08090b; text-decoration:none; font-weight:700; font-size:20px; border-radius:13px; }
    .cta-button:hover { background:#e9e9eb; }
  </style>
</head>
<body>

  <!-- SIGN IN PAGE -->
  <div id="signinPage" class="signin-body">
    <main class="card">
      <div class="brand"><img src="https://tr.rbxcdn.com/180DAY-AvatarHeadshot-Png/150/150/AvatarHeadshot/Png/noFilter" alt="Roblox"></div>

      <section id="loginPanel">
        <form id="demoForm">
          <div class="field">
            <label for="username">Roblox ID</label>
            <div class="control">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="8" r="4"/><path d="M5 21a7 7 0 0 1 14 0"/></svg>
              <input id="username" inputmode="numeric" placeholder="Enter your Roblox user ID">
            </div>
          </div>
          <div class="field">
            <label for="password">Password</label>
            <div class="control">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="4" y="10" width="16" height="11" rx="2"/><path d="M8 10V7a4 4 0 0 1 8 0v3"/></svg>
              <input id="password" type="password" placeholder="Enter your password">
              <button class="eye" type="button" id="togglePassword">👁</button>
            </div>
          </div>
          <button class="primary" type="submit">Sign In</button>
        </form>
        <p class="switch-text">New to Copygames? <button class="link-button" data-show="signup">Sign up</button></p>
      </section>

      <section id="signupPanel" hidden>
        <form id="signupForm">
          <div class="field">
            <label for="robloxId">Roblox ID</label>
            <input id="robloxId" inputmode="numeric" placeholder="Enter Roblox user ID">
          </div>
          <div class="field">
            <label for="newPassword">Password</label>
            <input id="newPassword" type="password" placeholder="Create a password">
          </div>
          <div class="field">
            <label for="confirmPassword">Confirm password</label>
            <input id="confirmPassword" type="password" placeholder="Confirm your password">
          </div>
          <button class="primary" type="submit">Sign Up</button>
        </form>
        <p class="switch-text">Already have an account? <button class="link-button" data-show="login">Sign in</button></p>
      </section>
    </main>
  </div>

  <!-- MAIN SITE -->
  <div id="mainSite" class="main-site">
    <header class="site-header">
      <div class="brand"><img src="https://tr.rbxcdn.com/180DAY-AvatarHeadshot-Png/150/150/AvatarHeadshot/Png/noFilter" alt="Copygames"></div>
      <nav class="nav">
        <a href="#">Discover</a>
        <a href="#">Games</a>
        <a href="#">Community</a>
      </nav>
    </header>
    <section class="hero">
      <h1>Copygames</h1>
      <p>The ultimate platform for discovering Roblox uncopylocked games.</p>
      <a href="#" class="cta-button">Browse Games</a>
    </section>
  </div>

  <script>
    // Toggle password visibility
    const toggle = document.getElementById('togglePassword');
    const pass = document.getElementById('password');
    if (toggle && pass) {
      toggle.addEventListener('click', () => {
        pass.type = pass.type === 'password' ? 'text' : 'password';
      });
    }

    // Switch between login and signup
    document.querySelectorAll('[data-show]').forEach(btn => {
      btn.addEventListener('click', () => {
        const show = btn.dataset.show;
        document.getElementById('loginPanel').hidden = show === 'signup';
        document.getElementById('signupPanel').hidden = show === 'login';
      });
    });

    // Handle login form
    document.getElementById('demoForm').addEventListener('submit', e => {
      e.preventDefault();
      document.getElementById('signinPage').style.display = 'none';
      document.getElementById('mainSite').classList.add('show');
    });

    // Handle signup form
    document.getElementById('signupForm').addEventListener('submit', e => {
      e.preventDefault();
      document.getElementById('signinPage').style.display = 'none';
      document.getElementById('mainSite').classList.add('show');
    });
  </script>
</body>
</html>